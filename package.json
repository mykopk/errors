{
  "name": "@myko.pk/errors",
  "version": "1.0.2",
  "description": "Shared error types for MYKOPK packages",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./codes": {
      "import": {
        "types": "./dist/codes.d.ts",
        "default": "./dist/codes.js"
      },
      "require": {
        "types": "./dist/codes.d.ts",
        "default": "./dist/codes.cjs"
      }
    }
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build",
    "prepack": "npm run build"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.7.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mykopk/errors.git"
  },
  "bugs": {
    "url": "https://github.com/mykopk/errors/issues"
  },
  "homepage": "https://github.com/mykopk/errors#readme"
}
